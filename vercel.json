{
  "version": 2,
  "builds": [
    { "src": "api/update.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "data.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/update", "dest": "/api/update.js" },
    { "src": "/data.json", "dest": "/data.json" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
